# Servidor
PORT=3000

# Base de datos SQL Server (connection string)
DB_CONNECTION_STRING=Server=NOMBRE_SERVIDOR\NOMBRE_INSTANCIA;Database=SistemaTickets;User Id=tu_usuario;Password=tu_password;TrustServerCertificate=True;Encrypt=False;Connect Timeout=30;

# JWT
JWT_SECRET=cambia_esto_por_una_clave_segura
JWT_EXPIRES_IN=8h

# Email (Gmail)
MAIL_USER=tu-correo@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM="Sistema de Tickets <tu-correo@gmail.com>"

# Integraciones externas (Google Forms, Email listener)
INTEGRATION_API_KEY=clave_secreta_para_integraciones

# Email listener (IMAP - misma cuenta de Gmail usada para envío)
IMAP_USER=tu-correo@gmail.com
IMAP_PASS=xxxx xxxx xxxx xxxx
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
EMAIL_LISTENER_INTERVAL_MS=120000
EMAIL_CATEGORIA_DEFAULT=General
